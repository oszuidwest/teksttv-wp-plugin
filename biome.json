{
    "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
    "files": {
        "includes": ["**/resources/ts/**/*.ts"]
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "complexity": {
                "noForEach": "off",
                "useOptionalChain": "off"
            },
            "correctness": {
                "noUnusedVariables": "warn"
            },
            "style": {
                "useTemplate": "off"
            }
        }
    },
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always"
        },
        "globals": ["jQuery", "tinymce", "wp", "teksttvPost", "TomSelect"]
    }
}
