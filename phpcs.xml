<?xml version="1.0"?>
<ruleset>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="nps"/>

    <file>./teksttv.php</file>
    <file>./src/</file>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <ini name="error_reporting" value="E_ALL &amp; ~E_DEPRECATED"/>

    <rule ref="Generic.Files.EndFileNewline"/>

    <rule ref="PSR12">
        <exclude name="PSR1.Files.SideEffects.FoundWithSymbols"/>
        <exclude name="PSR12.Files.FileHeader.SpacingAfterBlock"/>
        <exclude name="Generic.Files.LineLength.TooLong"/>
        <exclude name="PSR1.Methods.CamelCapsMethodName.NotCamelCaps"/>
    </rule>
    <rule ref="PHPCompatibilityWP"/>

    <rule ref="Squiz.Strings.DoubleQuoteUsage"/>
    <rule ref="Squiz.WhiteSpace.OperatorSpacing"/>
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>
    <rule ref="Generic.Arrays.ArrayIndent"/>
    <rule ref="Generic.WhiteSpace.ScopeIndent">
        <properties>
            <property name="exact" value="0"/>
        </properties>
    </rule>

    <rule ref="WordPress.Security">
        <!-- We escape manually in templates; the sniff can't track variables through method calls -->
        <exclude name="WordPress.Security.EscapeOutput.OutputNotEscaped"/>
        <exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
    </rule>
    <rule ref="WordPress.DB"/>
    <rule ref="WordPress.PHP">
        <exclude name="WordPress.PHP.YodaConditions"/>
        <exclude name="Universal.Operators.DisallowShortTernary"/>
    </rule>
    <rule ref="WordPress.WP">
        <exclude name="WordPress.WP.GlobalVariablesOverride"/>
    </rule>
    <rule ref="Generic.CodeAnalysis.EmptyPHPStatement"/>
</ruleset>
